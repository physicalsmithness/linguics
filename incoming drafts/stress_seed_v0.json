  "field_spec": {
    "_purpose": "The categorization is a DIAGNOSTIC: default stress is piana, so every other word is an exception the learner must DETECT. Each field answers 'what should have told them it was not piana, and did they use it?'.",
    "stress_pos": "int 1..4 from END. 1 tronca 2 piana 3 sdrucciola 4 bisdrucciola.",
    "syllables": "ordered orthographic syllables (Code-derived, hand-fixed on hiatus).",
    "syllable_count": "STORED: report filters by word length (2-syll vs 4-plus).",
    "accent_cue": "BOOLEAN, first-class. True = the stress is orthographically SIGNALLED by a final written accent (Smith's 'standard signal'). The accent_cue=true words are the signalled group; the report's real interest is the accent_cue=false words, where stress must be KNOWN.",
    "stress_source": "EVIDENCE / provenance (how we KNOW the position): orthographic_mark | dictionary | rule | author -> drives confidence.",
    "stress_confidence": "high | medium | low.",
    "stress_mechanism": "CAUSE / the detection cue = report drill-down L1. orthographic (accent_cue words, PRIMARY) | derivational | inflectional | lexical.",
    "stress_mechanism_detail": "L2, controlled per mechanism.",
    "etymological": "boolean flag; the learned/Greek subset, reportable on its own.",
    "stress_tags": "secondary memberships, e.g. an accented word's DEEPER cause 'lexical:loanword' — recorded but USUALLY EXCLUDED from the count ('you should have used the accent'). Membership AND treatment are TOGGLEABLE in the report.",
    "derived": "stress_class; option_count = min(syllable_count,4)."
  },
  "drill_generation_rule": {
    "items_are_derived": "generated from (form,syllables,stress_pos); provenance 'derived'.",
    "options": "word rendered once per option, a different syllable bold; option set = last min(syllable_count,4) positions; correct = stress_pos.",
    "short_words": "2 syll->2 options, 3->3, >=4->4; never an impossible position.",
    "matrix": "4x4 true x answered, row-normalised (DESIGN B2)."
  },
