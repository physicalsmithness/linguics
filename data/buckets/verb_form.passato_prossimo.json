[
  {
    "id": "verb_form.passato_prossimo",
    "parent_id": "verb_form",
    "language_code": "it",
    "label": "Passato prossimo (compound past)",
    "description": "The most common past tense in spoken and written Italian. Formed with an auxiliary (essere or avere, conjugated in the present) plus the past participle of the main verb. Three dimensions of difficulty: auxiliary choice, participle form, and (when essere is used or DOPs precede avere) participle agreement.",
    "cefr_importance": {"A1": "preview", "A2": "core", "B1": "core", "B2": "review", "C1": "review", "C2": "fluency"},
    "prerequisites": ["verb_form.present_indicative.avere", "verb_form.present_indicative.essere"],
    "attributes": {"is_aggregate": true, "topic_short": "pp"},
    "active": true,
    "version": 1
  },

  {
    "id": "verb_form.passato_prossimo.auxiliary",
    "parent_id": "verb_form.passato_prossimo",
    "language_code": "it",
    "label": "Auxiliary choice (essere vs avere)",
    "description": "Italian passato prossimo uses essere for certain verb classes (intransitive verbs of motion and change, reflexives, some others) and avere for transitive verbs and most other intransitives. Auxiliary choice determines whether the participle agrees with the subject.",
    "cefr_importance": {"A1": "preview", "A2": "core", "B1": "core", "B2": "review", "C1": "review", "C2": "fluency"},
    "prerequisites": [],
    "attributes": {"is_aggregate": true},
    "active": true,
    "version": 1
  },
  {
    "id": "verb_form.passato_prossimo.auxiliary.avere_default",
    "parent_id": "verb_form.passato_prossimo.auxiliary",
    "language_code": "it",
    "label": "Avere (default for transitive and many intransitive verbs)",
    "description": "The default auxiliary. Used for all transitive verbs (ho mangiato la pasta), and for many intransitives that aren't motion, change, or reflexive. Examples: dormire (ho dormito), lavorare (ho lavorato), parlare (ho parlato).",
    "cefr_importance": {"A1": "preview", "A2": "core", "B1": "core", "B2": "review", "C1": "review", "C2": "fluency"},
    "prerequisites": [],
    "attributes": {"common_miss": "using essere where avere is correct (sono mangiato la pasta)"},
    "active": true,
    "version": 1
  },
  {
    "id": "verb_form.passato_prossimo.auxiliary.essere_motion_intransitive",
    "parent_id": "verb_form.passato_prossimo.auxiliary",
    "language_code": "it",
    "label": "Essere with intransitive verbs of motion / change",
    "description": "Verbs of motion (andare, venire, partire, arrivare, uscire, entrare, salire, scendere, tornare) and change-of-state (nascere, morire, diventare, restare, stare in some senses) take essere as their auxiliary. The participle agrees with the subject.",
    "cefr_importance": {"A1": "preview", "A2": "core", "B1": "core", "B2": "review", "C1": "review", "C2": "fluency"},
    "prerequisites": [],
    "attributes": {"canonical_example": "sono andato/a/i/e", "common_miss": "ho andato (default-avere over-application)"},
    "active": true,
    "version": 1
  },
  {
    "id": "verb_form.passato_prossimo.auxiliary.essere_reflexive",
    "parent_id": "verb_form.passato_prossimo.auxiliary",
    "language_code": "it",
    "label": "Essere with reflexive verbs",
    "description": "All reflexive verbs take essere as their auxiliary: mi sono lavato, si è alzata, ci siamo divertiti. The participle agrees with the subject.",
    "cefr_importance": {"A1": "arcane", "A2": "preview", "B1": "core", "B2": "review", "C1": "review", "C2": "fluency"},
    "prerequisites": ["pronoun.reflexive"],
    "attributes": {"canonical_example": "mi sono lavato"},
    "active": true,
    "version": 1
  },
  {
    "id": "verb_form.passato_prossimo.auxiliary.essere_other_intransitive",
    "parent_id": "verb_form.passato_prossimo.auxiliary",
    "language_code": "it",
    "label": "Essere with other intransitives (no motion/change)",
    "description": "A residual class of intransitives that take essere despite not being about motion or visible change: piacere (mi è piaciuto), bastare, occorrere, sembrare, mancare. Memorise.",
    "cefr_importance": {"A1": "arcane", "A2": "preview", "B1": "core", "B2": "core", "C1": "review", "C2": "fluency"},
    "prerequisites": ["verb_form.passato_prossimo.auxiliary.essere_motion_intransitive"],
    "attributes": {"common_members": ["piacere", "bastare", "occorrere", "sembrare", "mancare"]},
    "active": true,
    "version": 1
  },
  {
    "id": "verb_form.passato_prossimo.auxiliary.ambiguous",
    "parent_id": "verb_form.passato_prossimo.auxiliary",
    "language_code": "it",
    "label": "Verbs that take either auxiliary, with meaning shift",
    "description": "A small set of verbs use avere when transitive and essere when intransitive, sometimes with different meanings. Examples: correre (ho corso il maratona / sono corso a casa), cambiare (ho cambiato lavoro / sono cambiato come persona), passare (ho passato l'esame / sono passato di qui).",
    "cefr_importance": {"A1": "arcane", "A2": "arcane", "B1": "preview", "B2": "core", "C1": "core", "C2": "review"},
    "prerequisites": ["verb_form.passato_prossimo.auxiliary.avere_default", "verb_form.passato_prossimo.auxiliary.essere_motion_intransitive"],
    "attributes": {"common_members": ["correre", "cambiare", "passare", "saltare", "volare"]},
    "active": true,
    "version": 1
  },

