[
  {
    "id": "adjective_agreement",
    "parent_id": null,
    "language_code": "it",
    "label": "Adjective agreement",
    "description": "Italian adjectives agree with the noun they modify in gender (masculine / feminine) and number (singular / plural). Rules vary by class (-o-class vs -e-class), with stem changes for some endings, position effects, and word-specific exceptions.",
    "cefr_importance": {
      "A1": "core",
      "A2": "core",
      "B1": "core",
      "B2": "review",
      "C1": "review",
      "C2": "review"
    },
    "prerequisites": [
      "gender",
      "number"
    ],
    "attributes": {
      "is_aggregate": true,
      "topic_short": "aa",
      "direction": "bidirectional"
    },
    "active": true,
    "version": 1
  },
  {
    "id": "adjective_agreement.o_class",
    "parent_id": "adjective_agreement",
    "language_code": "it",
    "label": "Class I adjectives (ending in -o)",
    "description": "Adjectives whose masculine singular ends in -o. Four-form pattern: -o (m sg), -a (f sg), -i (m pl), -e (f pl). Examples: rosso, alto, italiano, piccolo, simpatico.",
    "cefr_importance": {
      "A1": "core",
      "A2": "core",
      "B1": "review",
      "B2": "fluency",
      "C1": "fluency",
      "C2": "fluency"
    },
    "prerequisites": [],
    "attributes": {
      "is_aggregate": true,
      "form_pattern": "-o/-a/-i/-e",
      "direction": "production"
    },
    "active": true,
    "version": 1
  },
