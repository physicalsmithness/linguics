  {
    "id": "adjective_agreement.stem_changes.predictable.co_chi",
    "parent_id": "adjective_agreement.stem_changes.predictable",
    "language_code": "it",
    "label": "-co → -chi (masculine plural)",
    "description": "Most adjectives ending in -co form their masculine plural by inserting an h: bianco → bianchi, stanco → stanchi. Holds when the stress is on the penultimate syllable.",
