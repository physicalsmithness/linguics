  {
    "id": "adjective_agreement.stem_changes.harder.co_ci_vs_chi_stress",
    "parent_id": "adjective_agreement.stem_changes.harder",
    "language_code": "it",
    "label": "-co plurals: -chi vs -ci by stress",
    "description": "When stress falls on the antepenult, -co adjectives form their masculine plural with -ci (soft c), not -chi. Example: simpatico → simpatici. Compare bianco → bianchi (penultimate stress). The pattern is regular by stress but learners often mis-apply it.",
    "cefr_importance": {
      "A1": "arcane",
      "A2": "arcane",
      "B1": "preview",
      "B2": "core",
      "C1": "core",
      "C2": "review"
    },
    "prerequisites": [
      "adjective_agreement.stem_changes.predictable.co_chi"
    ],
    "attributes": {
      "transform": "-co (antepenult stress) → -ci",
      "canonical_example": "simpatici",
      "common_miss": "simpatichi (over-applying -chi)",
      "direction": "production"
    },
    "active": true,
    "version": 1
  },
