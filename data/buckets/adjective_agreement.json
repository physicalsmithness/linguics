  {
    "id": "adjective_agreement.special.bello",
    "parent_id": "adjective_agreement.special",
    "language_code": "it",
    "label": "bello (behaves like the definite article)",
    "description": "Before a noun, bello takes the form of the definite article that would precede that noun: bel libro (il), bello zaino (lo), bell'amico (l'), bella casa (la), bei libri (i), begli zaini (gli), belle case (le). After a noun, it has the standard Class I forms (bello, bella, belli, belle).",
    "cefr_importance": {
      "A1": "preview",
      "A2": "core",
      "B1": "core",
      "B2": "review",
      "C1": "review",
      "C2": "fluency"
    },
    "prerequisites": [
      "adjective_agreement.position.pre_noun_canonical",
      "article"
    ],
    "attributes": {
      "forms_pre_noun": [
        "bel",
        "bello",
        "bell'",
        "bella",
        "bei",
        "begli",
        "belle"
      ],
      "common_miss": "bello libro (wrong allomorph)",
      "direction": "bidirectional"
    },
    "active": true,
    "version": 1
  },
  {
    "id": "adjective_agreement.special.buono",
    "parent_id": "adjective_agreement.special",
    "language_code": "it",
    "label": "buono (behaves like the indefinite article in the singular)",
    "description": "In the singular before a noun, buono takes article-like forms: buon libro (un), buono studente (uno), buon amico (un, but with elision rare), buona casa, buon'amica (un'). In the plural and after the noun, standard Class I forms (buoni, buone).",
