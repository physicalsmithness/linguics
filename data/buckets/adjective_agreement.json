  },
  {
    "id": "adjective_agreement.special.grande_prenominal",
    "parent_id": "adjective_agreement.special",
    "language_code": "it",
    "label": "grande → gran before some pre-noun positions",
    "description": "When grande precedes a singular noun, it may shorten to gran: un gran libro, un gran successo. The shorter form is optional and stylistic; un grande libro is also fine. Plural and feminine plural keep standard forms (grandi).",
