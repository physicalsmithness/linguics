  {
    "id": "adjective_agreement.stem_changes",
    "parent_id": "adjective_agreement",
    "language_code": "it",
    "label": "Stem changes in adjective plurals",
    "description": "When a Class I adjective's stem ends in c or g, the plural may need an h inserted to preserve the hard sound. Rules range from predictable (most -co, -ga) to irregular.",
