  {
    "id": "adjective_agreement.position",
    "parent_id": "adjective_agreement",
    "language_code": "it",
    "label": "Adjective position relative to noun",
    "description": "Most Italian adjectives follow the noun (casa rossa), but a small set canonically precede (bel libro). A subset can appear on either side, with a semantic shift.",
    "cefr_importance": {
      "A1": "preview",
      "A2": "core",
      "B1": "core",
      "B2": "review",
      "C1": "review",
      "C2": "fluency"
    },
    "prerequisites": [
      "adjective_agreement.o_class"
    ],
    "attributes": {
      "is_aggregate": true,
      "direction": "production"
    },
    "active": true,
    "version": 1
  },
  {
    "id": "adjective_agreement.position.post_noun_default",
    "parent_id": "adjective_agreement.position",
    "language_code": "it",
    "label": "Post-noun position (the default)",
    "description": "Most descriptive adjectives follow the noun: la casa rossa, il libro interessante. Misplacing such an adjective before the noun marks the learner as English-influenced.",
    "cefr_importance": {
      "A1": "preview",
      "A2": "core",
      "B1": "core",
      "B2": "review",
      "C1": "review",
      "C2": "fluency"
    },
    "prerequisites": [],
    "attributes": {
      "canonical_example": "la casa rossa",
      "common_miss": "la rossa casa (English-style fronting)",
      "direction": "production"
    },
    "active": true,
    "version": 1
  },
  {
    "id": "adjective_agreement.position.pre_noun_canonical",
    "parent_id": "adjective_agreement.position",
    "language_code": "it",
    "label": "Adjectives that canonically precede the noun",
    "description": "A small set: bello, brutto, buono, cattivo, grande, piccolo, nuovo, vecchio, giovane, bravo, lungo, breve. They can also follow, with a slight emphasis shift; but the unmarked position is before.",
    "cefr_importance": {
      "A1": "preview",
      "A2": "core",
      "B1": "core",
      "B2": "review",
      "C1": "review",
      "C2": "fluency"
    },
    "prerequisites": [],
    "attributes": {
      "canonical_example": "un bel libro / un buon vino / una piccola casa",
      "direction": "production"
    },
    "active": true,
    "version": 1
  },
  {
    "id": "adjective_agreement.position.semantic_shift",
    "parent_id": "adjective_agreement.position",
    "language_code": "it",
    "label": "Position changes meaning",
    "description": "For a subset of adjectives, position shifts the meaning. Pre-noun is usually figurative or emphatic, post-noun is usually literal. Examples: un vecchio amico (long-standing friend) vs un amico vecchio (an elderly friend); un grande uomo (a great man) vs un uomo grande (a tall/big man); povero (poor in spirit vs financially poor).",
    "cefr_importance": {
      "A1": "arcane",
      "A2": "preview",
      "B1": "preview",
      "B2": "core",
      "C1": "core",
      "C2": "review"
    },
    "prerequisites": [
      "adjective_agreement.position.pre_noun_canonical"
    ],
    "attributes": {
      "canonical_example": "un vecchio amico vs un amico vecchio",
      "direction": "bidirectional",
      "is_aggregate": true
    },
    "active": true,
    "version": 1
  },
