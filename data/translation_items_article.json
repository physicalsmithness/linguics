        "register": "neutral",
        "notes": "Feminine noun before a vowel: un' with the apostrophe."
      }
    ],
    "topic": "article",
    "register": "neutral",
    "difficulty": 2,
    "cefr_level_target": "A1",
    "required_buckets": [
      "article.indefinite.forms"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "friend",
        "language": "en",
        "aspects": {
          "translation": {
            "reveal": "amica - friend (female)",
            "bucket": "vocabulary.it.amica.noun.translation"
          },
          "gender": {
            "reveal": "feminine (f)",
            "bucket": "vocabulary.it.amica.noun.gender"
          }
        }
      }
    ],
    "explanation": "\"Ho un'amica a Napoli.\" The feminine una drops its vowel before a noun beginning with a vowel and takes an apostrophe: un'amica. This elision is the feminine's own; the masculine stays un amico.",
