    "difficulty": 2,
    "cefr_level_target": "A1",
    "required_buckets": [
      "article.definite.forms",
      "article.indefinite.forms"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "student",
        "language": "en",
        "aspects": {
          "translation": {
            "reveal": "studente - student",
            "bucket": "vocabulary.it.studente.noun.translation"
          },
          "gender": {
            "reveal": "masculine (m)",
            "bucket": "vocabulary.it.studente.noun.gender"
          }
        }
      },
      {
        "lemma": "rucksack",
        "language": "en",
        "aspects": {
          "translation": {
            "reveal": "zaino - rucksack",
