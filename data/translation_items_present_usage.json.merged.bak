[
  {
    "external_id": "trans_pu_en_it_hab_01",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "I work in Milan but I live in Como.",
    "reference_translations": [
      {
        "text": "Lavoro a Milano ma abito a Como.",
        "register": "neutral",
        "notes": "Standard: two settled facts, both in the plain present, subject pronoun dropped."
      },
      {
        "text": "Lavoro a Milano ma vivo a Como.",
        "register": "neutral",
        "notes": "vivere and abitare are both fine for 'live' with a place."
      },
      {
        "text": "Sto lavorando a Milano ma vivo a Como.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: grammatical Italian, but the English simple present states a settled habit, and sto lavorando recasts the job as a temporary arrangement. The habitual context makes the plain present clearly the right rendering, so per the context-dependent progressive policy give partial credit (around 0.6) on the habitual bucket, with the full not-wrong-but explanation."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 1,
    "cefr_level_target": "A1",
    "required_buckets": [
      "verb_form.present_indicative.usage.general_habitual"
    ],
    "optional_buckets": [
      "verb_form.present_indicative.formation.regular_are",
      "verb_form.present_indicative.formation.regular_ere"
    ],
    "vocab_help": [
      {
        "lemma": "work",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to work - lavorare", "bucket": "vocabulary.it.lavorare.translation" }
        }
      },
      {
        "lemma": "live",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to live - abitare", "bucket": "vocabulary.it.abitare.translation" }
        }
      }
    ],
    "explanation": "Lavoro a Milano ma abito a Como ('I work in Milan but I live in Como'). Where you work and where you live are standing facts about your life, habits in the broad sense, and Italian states them in the plain present: lavoro, abito. English's simple present maps straight onto it. Reaching for sto lavorando is not ungrammatical, but it changes the meaning: it presents the Milan job as a temporary state of affairs rather than the settled one the English states.",
    "version": 1
  },
  {
    "external_id": "trans_pu_en_it_hab_02",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "Water boils at a hundred degrees.",
    "reference_translations": [
      {
        "text": "L'acqua bolle a cento gradi.",
        "register": "neutral",
        "notes": "Standard. Note Italian wants the definite article on the generic subject: l'acqua, not bare acqua."
      },
      {
        "text": "L'acqua bolle a 100 gradi.",
        "register": "neutral",
        "notes": "Digits acceptable."
      },
      {
        "text": "L'acqua sta bollendo a cento gradi.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: grammatical, but it turns a timeless truth into one pot boiling right now. A general truth is squarely a plain-present context, so per the context-dependent progressive policy give partial credit (around 0.6) on the habitual bucket, with the full explanation."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 1,
    "cefr_level_target": "A1",
    "required_buckets": [
      "verb_form.present_indicative.usage.general_habitual"
    ],
    "optional_buckets": [
      "verb_form.present_indicative.formation.regular_ire"
    ],
    "vocab_help": [
      {
        "lemma": "boil",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to boil - bollire", "bucket": "vocabulary.it.bollire.translation" }
        }
      },
      {
        "lemma": "water",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "water - acqua", "bucket": "vocabulary.it.acqua.translation" }
        }
      },
      {
        "lemma": "degrees",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "degree - grado", "bucket": "vocabulary.it.grado.translation" }
        }
      }
    ],
    "explanation": "L'acqua bolle a cento gradi ('Water boils at a hundred degrees'). A fact that is always true, a general truth, lives in the plain present in both languages: bolle. There is nothing happening at any particular moment, so the progressive sta bollendo would mis-describe the physics lesson as a kitchen scene. Note the article: generic subjects in Italian still take the definite article, l'acqua.",
    "version": 1
  },
  {
    "external_id": "trans_pu_it_en_hab_01",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "Ogni estate andiamo al mare dai nonni.",
    "reference_translations": [
      {
        "text": "Every summer we go to the seaside to stay with our grandparents.",
        "register": "neutral",
        "notes": "dai nonni = to our grandparents' place; any natural rendering of that (to our grandparents', to stay with our grandparents) is fine."
      },
      {
        "text": "Every summer we go to the beach at our grandparents'.",
        "register": "neutral",
        "notes": "Slightly more literal; acceptable."
      },
      {
        "text": "Every summer we are going to the seaside to our grandparents'.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: 'ogni estate' marks a habit, and habitual English requires the simple present 'we go'. 'We are going' misses the habitual reading (it suggests a plan for this summer). Miss on the habitual bucket."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 2,
    "cefr_level_target": "A2",
    "required_buckets": [
      "verb_form.present_indicative.usage.general_habitual"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "estate",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "estate - summer", "bucket": "vocabulary.it.estate.translation" }
        }
      },
      {
        "lemma": "mare",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "mare - sea", "bucket": "vocabulary.it.mare.translation" }
        }
      },
      {
        "lemma": "nonni",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "nonno - grandfather", "bucket": "vocabulary.it.nonno.translation" }
        }
      }
    ],
    "explanation": "Ogni estate andiamo al mare dai nonni means 'Every summer we go to the seaside to our grandparents'.' The marker ogni estate makes this a habit, and habits demand the simple present in English: 'we go', never 'we are going', which would read as a plan for one particular summer. Going the other way this is where English speakers over-trust the -ing form; coming this way the trap is the same in reverse. Da + a person means at or to that person's place: dai nonni, 'at our grandparents'.'",
    "version": 1
  },
  {
    "external_id": "trans_pu_en_it_now_01",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "I can't talk now, I'm driving.",
    "reference_translations": [
      {
        "text": "Non posso parlare adesso, sto guidando.",
        "register": "neutral",
        "notes": "Fully natural with the progressive."
      },
      {
        "text": "Non posso parlare adesso, guido.",
        "register": "neutral",
        "notes": "MARKER GUIDANCE: the plain present is equally correct and idiomatic; full credit. The diagnostic is that the learner does NOT need stare + gerundio to render English 'I'm driving'."
      },
      {
        "text": "Non posso parlare ora, sto guidando.",
        "register": "neutral",
        "notes": "ora / adesso interchangeable."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 1,
    "cefr_level_target": "A1",
    "required_buckets": [
      "verb_form.present_indicative.usage.ongoing_now"
    ],
    "optional_buckets": [
      "verb_form.gerundio.formation",
      "verb_form.present_indicative.formation.modal_verbs"
    ],
    "vocab_help": [
      {
        "lemma": "drive",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to drive - guidare", "bucket": "vocabulary.it.guidare.translation" }
        }
      },
      {
        "lemma": "talk",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to talk - parlare", "bucket": "vocabulary.it.parlare.translation" }
        }
      },
      {
        "lemma": "now",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "now - adesso", "bucket": "vocabulary.it.adesso.translation" }
        }
      }
    ],
    "explanation": "Non posso parlare adesso: guido / sto guidando ('I can't talk now, I'm driving'). Something happening at this very moment is a happening-now use, and Italian gives you two equally good renderings: the plain present guido, or the stare + gerundio progressive sto guidando. English has no choice, it must say 'I'm driving'; Italian never needs the progressive, it only offers it. Either answer is fully right; what would be wrong is believing the plain present is too weak.",
    "version": 1
  },
  {
    "external_id": "trans_pu_en_it_now_02",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "What are you doing? I'm making coffee.",
    "reference_translations": [
      {
        "text": "Cosa fai? Preparo il caffè.",
        "register": "informal",
        "notes": "The everyday exchange, both halves in the plain present. faccio il caffè equally good for the second half."
      },
      {
        "text": "Che cosa stai facendo? Sto preparando il caffè.",
        "register": "informal",
        "notes": "MARKER GUIDANCE: progressive in either or both halves is equally correct; full credit. Mixed renderings (plain question, progressive answer, or vice versa) are also fine."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "informal",
    "difficulty": 1,
    "cefr_level_target": "A2",
    "required_buckets": [
      "verb_form.present_indicative.usage.ongoing_now"
    ],
    "optional_buckets": [
      "verb_form.gerundio.formation",
      "verb_form.present_indicative.formation.irregular.monosyllabic_core"
    ],
    "vocab_help": [
      {
        "lemma": "coffee",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "coffee - caffè", "bucket": "vocabulary.it.caffè.translation" }
        }
      },
      {
        "lemma": "make",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to make, to prepare - preparare", "bucket": "vocabulary.it.preparare.translation" }
        }
      }
    ],
    "explanation": "Cosa fai? Preparo il caffè ('What are you doing? I'm making coffee'). Both halves are happening right now, and the plain present covers both: fai where English needs 'are you doing', preparo where English needs 'I'm making'. The stare + gerundio progressive (stai facendo, sto preparando) is just as natural; the asymmetry to internalise is that English is forced into the -ing form while Italian's everyday default is the bare present.",
    "version": 1
  },
  {
    "external_id": "trans_pu_it_en_now_01",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "— Dove sei? — Sono in cucina, preparo la cena.",
    "reference_translations": [
      {
        "text": "Where are you? I'm in the kitchen, I'm making dinner.",
        "register": "neutral",
        "notes": "The Italian plain present preparo must surface as the English progressive: making / preparing / cooking dinner all fine."
      },
      {
        "text": "Where are you? I'm in the kitchen making dinner.",
        "register": "neutral",
        "notes": "Fused rendering, very natural."
      },
      {
        "text": "Where are you? I'm in the kitchen, I make dinner.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: 'I make dinner' is the classic reverse error: the English simple present turns a happening-now action into a habit ('I'm the one who cooks around here'). Miss on the ongoing-now bucket."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 2,
    "cefr_level_target": "A1",
    "required_buckets": [
      "verb_form.present_indicative.usage.ongoing_now"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "cucina",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "cucina - kitchen", "bucket": "vocabulary.it.cucina.translation" }
        }
      },
      {
        "lemma": "cena",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "cena - dinner", "bucket": "vocabulary.it.cena.translation" }
        }
      },
      {
        "lemma": "preparare",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "preparare - to prepare, to make", "bucket": "vocabulary.it.preparare.translation" }
        }
      }
    ],
    "explanation": "Sono in cucina, preparo la cena means 'I'm in the kitchen, I'm making dinner.' The Italian plain present preparo is doing happening-now work here, so English must render it with the progressive: 'I'm making dinner'. The simple present 'I make dinner' would flip the meaning into a habit, who usually cooks, which is not what the speaker on the phone is saying. Italian gets to be relaxed about this distinction; English does not.",
    "version": 1
  },
  {
    "external_id": "trans_pu_it_en_now_02",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "Dalla finestra vedo le montagne e sento le campane.",
    "reference_translations": [
      {
        "text": "From the window I can see the mountains and hear the bells.",
        "register": "neutral",
        "notes": "The most natural English: perception verbs take 'can' for present perception."
      },
      {
        "text": "From the window I see the mountains and hear the bells.",
        "register": "neutral",
        "notes": "Correct, slightly flatter than the 'can see' rendering; full credit."
      },
      {
        "text": "From the window I am seeing the mountains and hearing the bells.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: English perception verbs resist the progressive just as Italian ones do; 'I am seeing' is wrong here. Miss on the ongoing-now bucket."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 2,
    "cefr_level_target": "A2",
    "required_buckets": [
      "verb_form.present_indicative.usage.ongoing_now"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "finestra",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "finestra - window", "bucket": "vocabulary.it.finestra.translation" }
        }
      },
      {
        "lemma": "montagne",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "montagna - mountain", "bucket": "vocabulary.it.montagna.translation" }
        }
      },
      {
        "lemma": "campane",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "campana - bell", "bucket": "vocabulary.it.campana.translation" }
        }
      },
      {
        "lemma": "sentire",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "sentire - to hear, to feel", "bucket": "vocabulary.it.sentire.translation" }
        }
      }
    ],
    "explanation": "Dalla finestra vedo le montagne e sento le campane means 'From the window I can see the mountains and hear the bells.' Seeing and hearing are states of perceiving, not activities, and both languages keep such stative verbs out of the progressive: Italian says the plain vedo and sento, and English says 'I see' or, most naturally, 'I can see'. That little 'can' is the idiomatic English dressing for present perception; what English must not do is say 'I am seeing the mountains'.",
    "version": 1
  },
  {
    "external_id": "trans_pu_en_it_state_01",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "I'm hungry and thirsty after the journey.",
    "reference_translations": [
      {
        "text": "Ho fame e sete dopo il viaggio.",
        "register": "neutral",
        "notes": "The avere idiom: physical states are things you have in Italian."
      },
      {
        "text": "Dopo il viaggio ho fame e sete.",
        "register": "neutral",
        "notes": "Fronted time phrase, equally natural."
      },
      {
        "text": "Sono affamato e assetato dopo il viaggio.",
        "register": "neutral",
        "notes": "MARKER GUIDANCE: grammatical and understandable, but marked: the adjectives are stronger (nearer 'starving and parched') and the everyday rendering is the avere idiom. Full credit, with an explanation steering to ho fame e sete as the natural default."
      },
      {
        "text": "Sono fame e sete dopo il viaggio.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: the word-for-word calque of English 'to be'; ungrammatical. Miss on the states bucket."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 1,
    "cefr_level_target": "A1",
    "required_buckets": [
      "verb_form.present_indicative.usage.states_facts"
    ],
    "optional_buckets": [
      "verb_form.present_indicative.formation.irregular.avere"
    ],
    "vocab_help": [
      {
        "lemma": "journey",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "journey - viaggio", "bucket": "vocabulary.it.viaggio.translation" }
        }
      }
    ],
    "explanation": "Ho fame e sete dopo il viaggio ('I'm hungry and thirsty after the journey'). Physical states, hunger, thirst, heat, cold, sleepiness, are things you have in Italian, so the idiom is avere + noun in the plain present: ho fame, ho sete, literally 'I have hunger, I have thirst'. Sono affamato e assetato exists but is stronger and less everyday; sono fame is the direct English calque and is never said. No vocab help is offered for 'hungry' and 'thirsty' because reaching for the idiom is exactly what the item tests.",
    "version": 1
  },
  {
    "external_id": "trans_pu_en_it_state_02",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "My sister is seven years old.",
    "reference_translations": [
      {
        "text": "Mia sorella ha sette anni.",
        "register": "neutral",
        "notes": "Standard: age with avere, no article on the singular family member with mia."
      },
      {
        "text": "Mia sorella è sette anni.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: the essere calque of English 'is seven years old'; ungrammatical. Miss on the states bucket."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 1,
    "cefr_level_target": "A1",
    "required_buckets": [
      "verb_form.present_indicative.usage.states_facts"
    ],
    "optional_buckets": [
      "verb_form.present_indicative.formation.irregular.avere"
    ],
    "vocab_help": [
      {
        "lemma": "sister",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "sister - sorella", "bucket": "vocabulary.it.sorella.translation" },
          "gender": { "reveal": "feminine (f)", "bucket": "vocabulary.it.sorella.gender" }
        }
      },
      {
        "lemma": "year",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "year - anno", "bucket": "vocabulary.it.anno.translation" }
        }
      }
    ],
    "explanation": "Mia sorella ha sette anni ('My sister is seven years old'). Age is a state you have in Italian: avere + number + anni, literally 'to have seven years', in the plain present. The essere rendering è sette anni is the classic English calque and always wrong. Note also that anni must appear: unlike English, which can drop 'years old' ('she is seven'), Italian keeps the noun, ha sette anni.",
    "version": 1
  },
  {
    "external_id": "trans_pu_it_en_state_01",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "Abbiamo freddo e vogliamo tornare a casa.",
    "reference_translations": [
      {
        "text": "We're cold and we want to go home.",
        "register": "neutral",
        "notes": "avere freddo surfaces as English 'to be cold'; tornare a casa as 'go home' or 'go back home'."
      },
      {
        "text": "We are cold and want to go back home.",
        "register": "neutral",
        "notes": "Equally fine."
      },
      {
        "text": "We have cold and want to return home.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: 'we have cold' is the calque of the Italian idiom and wrong in English. Miss on the states bucket. ('return home' alone is stiff but acceptable; the miss is 'have cold'.)"
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 2,
    "cefr_level_target": "A2",
    "required_buckets": [
      "verb_form.present_indicative.usage.states_facts"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "freddo",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "freddo - cold", "bucket": "vocabulary.it.freddo.translation" }
        }
      },
      {
        "lemma": "tornare",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "tornare - to go back, to return", "bucket": "vocabulary.it.tornare.translation" }
        }
      }
    ],
    "explanation": "Abbiamo freddo e vogliamo tornare a casa means 'We're cold and we want to go home.' The avere idiom runs in both directions: Italian has states (abbiamo freddo, 'we have cold'), English is them ('we're cold'), and a translator must swap the verb, not the words. Both verbs stay in the plain present: being cold and wanting are states, so neither language reaches for a progressive here ('we are wanting' is as bad in English as stiamo volendo is in Italian).",
    "version": 1
  },
  {
    "external_id": "trans_pu_en_it_instr_01",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "You add the salt at the end.",
    "reference_translations": [
      {
        "text": "Si aggiunge il sale alla fine.",
        "register": "neutral",
        "notes": "The si-impersonal, the classic recipe voice: instructional English 'you' is generic, and si + 3sg present renders it."
      },
      {
        "text": "Aggiungi il sale alla fine.",
        "register": "informal",
        "notes": "The informal tu present, also a standard recipe voice; full credit. The voi form (aggiungete) is likewise acceptable."
      },
      {
        "text": "Si aggiungono il sale alla fine.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "MARKER GUIDANCE: agreement slip: il sale is singular, so the si-impersonal verb must be 3sg (si aggiunge). Miss on the instructions bucket."
      }
    ],
    "topic": "verb_form.present_indicative",
    "register": "neutral",
    "difficulty": 2,
    "cefr_level_target": "B1",
    "required_buckets": [
      "verb_form.present_indicative.usage.instructions"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "add",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to add - aggiungere", "bucket": "vocabulary.it.aggiungere.translation" }
        }
      },
      {
        "lemma": "salt",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "salt - sale", "bucket": "vocabulary.it.sale.translation" },
          "gender": { "reveal": "masculine (m)", "bucket": "vocabulary.it.sale.gender" }
        }
      }
    ],
    "explanation": "Si aggiunge il sale alla fine ('You add the salt at the end'). The 'you' of instructions is nobody in particular, it means 'one', and Italian's favourite way to say what-one-does is the si-impersonal: si plus the verb in the plain present, si aggiunge. The verb agrees with the thing added, singular il sale, so 3sg. The direct address forms, tu aggiungi or voi aggiungete, are also standard recipe voices and fully acceptable; what the plain present must not become is a future or a laboured command.",
    "version": 1
  },
  {
    "external_id": "trans_pu_it_en_instr_01",
