    "source_text": "Da qui si vede il duomo e si arriva in piazza in cinque minuti.",
    "reference_translations": [
      {
        "text": "From here you can see the cathedral and you get to the square in five minutes.",
        "register": "neutral",
        "notes": "Generic 'you' is the natural English for the si-impersonal; 'can see' the natural perception rendering."
      },
      {
        "text": "From here one sees the cathedral and reaches the square in five minutes.",
        "register": "formal",
        "notes": "The 'one' rendering: correct but stiff in everyday English; full credit."
