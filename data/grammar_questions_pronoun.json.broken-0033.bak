    "cefr_level_target": "B1",
    "prompt": "Rephrase with a stressed form for emphasis: 'Mi piace il caffè.' → '____ ____ piace il caffè.' (emphasising: it's ME who likes it)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
