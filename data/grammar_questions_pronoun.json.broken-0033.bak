  {
    "external_id": "op_refl_essere_01",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "reflexive.essere_in_compound",
    "difficulty": 2,
    "cefr_level_target": "B1",
    "prompt": "Complete: 'Stamattina mi ____ alzato presto.' (= I, masculine, got up)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.reflexive.essere_in_compound",
        "label": "Reflexive PP takes essere",
        "any_phrases": [
          "sono"
        ],
        "must_not_include": [
          "ho",
          "abbia"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "alzato",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "alzarsi - to get up",
            "bucket": "vocabulary.it.alzarsi.translation"
          }
        }
      }
    ],
    "explanation": "'Stamattina mi sono alzato presto' means 'This morning I got up early'. Reflexive verbs in Italian always take essere as their auxiliary in compound tenses, regardless of what the non-reflexive verb would take. The participle then agrees with the subject. Stack: mi + sono + alzato giving 'mi sono alzato'.",
    "examiner_note": "Hot spot: common miss 'mi ho alzato'. The bucket attributes to the reflexive-essere rule, cross-referenced with verb_form.passato_prossimo.auxiliary.essere_reflexive.",
    "version": 1
  },
  {
    "external_id": "op_refl_essere_02",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "reflexive.essere_in_compound",
    "difficulty": 2,
    "cefr_level_target": "B1",
    "prompt": "Complete: 'Anna ____ ____ divertita molto alla festa.' (auxiliary + participle, agreeing with subject)",
    "type": "short",
    "marks": 2,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
