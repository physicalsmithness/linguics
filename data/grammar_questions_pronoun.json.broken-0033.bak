        "label": "Piacere takes IOP, 1sg mi",
        "any_phrases": [
          "mi"
        ],
        "must_not_include": [
          "io",
          "me",
          "a me"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "piace",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "piacere - to please / be pleasing",
            "bucket": "vocabulary.it.piacere.translation"
          },
          "requires_iop": {
            "reveal": "the English 'subject' surfaces as IOP",
            "bucket": "vocabulary.it.piacere.requires_iop"
          }
        }
      }
    ],
    "explanation": "'Mi piace la pizza italiana' means 'I like Italian pizza'. Italian piacere flips the English mapping: 'Mi piace la pizza' is literally 'to me it pleases the pizza'. The experiencer (the liker) surfaces as an IOP, and the verb agrees with the thing liked (the grammatical subject).",
    "examiner_note": "Hot spot. Common miss: 'Io piaccio la pizza' (English-style mapping).",
    "version": 1
  },
