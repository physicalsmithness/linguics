    "vocab_help": [
      {
        "lemma": "parlato",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "parlare - to speak (parlare di = to talk about)",
            "bucket": "vocabulary.it.parlare.translation"
          }
        }
      }
    ],
    "explanation": "'Hai parlato della tua idea? Sì, ne ho parlato con tutti' means 'Have you talked about your idea? Yes, I've talked about it with everyone'. Parlare DI qualcosa takes a di-phrase, replaced by the pronominal ne. The participle stays invariable: pronominal ne does NOT trigger participle agreement (only partitive ne does).",
    "examiner_note": "Diagnostic: parlare-di → ne, not ci. (ci would attach to verbs that take a-preposition, like pensare a.)",
    "version": 1
  },
