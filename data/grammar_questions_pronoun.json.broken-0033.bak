    "type": "mcq",
    "marks": 1,
    "choices": [
      "Mi fido di lei.",
      "La mi fido.",
      "Le mi fido.",
      "Mi fido la."
    ],
    "answer_index": 0,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.special.stressed_forms",
        "label": "fidarsi di + stressed pronoun (no clitic 'di-her')",
        "any_phrases": [
          "Mi fido di lei"
        ],
        "must_not_include": [
