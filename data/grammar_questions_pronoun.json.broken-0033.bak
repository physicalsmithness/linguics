    "difficulty": 3,
    "cefr_level_target": "B2",
    "prompt": "Complete: 'Non ____ niente!' (= I don't care at all, from fregarsene, 1sg)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.ne.pronominal_idiomatic_verbs",
        "label": "fregarsene 1sg (me ne frega)",
        "any_phrases": [
          "me ne frega",
          "Me ne frega"
        ],
        "must_not_include": [
          "mi ne frega",
          "ne mi frega"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "frega",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "fregarsene - to not care (colloquial)",
            "bucket": "vocabulary.it.fregarsene.translation"
          }
        }
      }
    ],
    "explanation": "'Non me ne frega niente!' means 'I couldn't care less!'. Fregarsene is a pronominal idiomatic verb meaning 'not give a damn'. The ne is lexicalised: it doesn't refer to anything specific, it just belongs to the verb. 1sg: mi shifts to me before ne. Stack: me + ne + frega.",
    "examiner_note": "Pronominal-idiom family (ne lexicalised into a non-motion pattern). Sits with starsene, intendersene, uscirsene.",
    "version": 1
  },
  {
