    ],
    "vocab_help": [],
    "explanation": "'Li ho visti in giardino' means 'I've seen them in the garden'. The plural DOP li does NOT undergo elision before a vowel. 'L'ho visti' would collide with the singular and isn't used.",
    "examiner_note": "Diagnostic against over-extending the lo/la elision rule.",
    "version": 1
  },
  {
    "external_id": "op_dop_nonelide_02",
