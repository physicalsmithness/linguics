  {
    "external_id": "op_dop_lo_03",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.lo",
    "difficulty": 2,
    "cefr_level_target": "B1",
    "prompt": "Replace 'Marco' with a pronoun: 'Vedo Marco al bar.' → '____ vedo al bar.'",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.lo",
        "label": "DOP m.sg lo for a masculine person",
        "any_phrases": [
          "lo"
        ],
        "must_not_include": [
          "gli",
          "lui",
          "li",
          "la"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "vedo",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "vedere - to see",
            "bucket": "vocabulary.it.vedere.translation"
          }
        }
      }
    ],
    "explanation": "'Lo vedo al bar' means 'I see him at the bar'. Vedere takes a direct object. For a masculine human, the DOP is still lo, not gli (gli is the IOP). The argument structure of vedere fixes the role: 'lo vedo' = 'I see him'.",
    "examiner_note": "Diagnostic miss: 'gli' (confusing DOP with IOP for masculine person).",
    "version": 1
  },
  {
