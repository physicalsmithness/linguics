  {
    "external_id": "op_dop_formal_La_01",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.formal_La",
    "difficulty": 2,
    "cefr_level_target": "B1",
    "prompt": "Write a polite form. 'I'll see you tomorrow, signor Bianchi.' → '____ vedo domani, signor Bianchi.'",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.formal_La",
        "label": "DOP formal La",
        "any_phrases": [
          "La",
          "la"
        ],
        "must_not_include": [
          "ti",
          "lo",
          "le",
          "voi"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "vedo",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "vedere - to see",
            "bucket": "vocabulary.it.vedere.translation"
          }
        }
      }
    ],
    "explanation": "'La vedo domani, signor Bianchi' means 'I'll see you tomorrow, Mr Bianchi'. Italian uses formal address (Lei) for polite singular 'you'. The DOP for formal address is La, capitalised by convention in writing. The surface form matches fem 3sg, but the meaning is 'you', not 'her'.",
    "examiner_note": "Accepts both 'La' (preferred in formal writing) and lowercase 'la'.",
    "version": 1
  },
  {
    "external_id": "op_dop_formal_La_02",
    "language_code": "it",
    "topic": "pronoun",
