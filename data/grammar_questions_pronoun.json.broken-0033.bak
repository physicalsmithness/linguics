        ]
      }
    ],
    "vocab_help": [],
    "explanation": "'L'ho visto ieri' means 'I saw him yesterday'. In a compound tense the clitic sits in pre-verb position before the auxiliary, not between auxiliary and participle. Lo undergoes elision to l' before ho. Stack: l' + ho + visto.",
    "examiner_note": "Common miss: 'ho lo visto' (placing between aux and participle).",
    "version": 1
  },
  {
