[
  {
    "external_id": "op_dop_mi_01",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.mi",
    "difficulty": 1,
    "cefr_level_target": "A2",
    "prompt": "Replace 'me' with a pronoun: 'Marco vede me.' → 'Marco ____ vede.'",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.mi",
        "label": "DOP 1sg mi",
        "any_phrases": [
          "mi"
        ],
        "must_not_include": [
          "me",
          "io",
          "a me"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "vede",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "vedere - to see",
            "bucket": "vocabulary.it.vedere.translation"
          }
        }
      }
    ],
    "explanation": "'Marco mi vede' means 'Marco sees me'. Italian has two parallel object forms for 1sg: a small everyday one and a stronger emphatic one. The clitic is mi (default, pre-verb). The stressed pronoun me appears after prepositions (a me, con me) or for contrast.",
    "examiner_note": "Common miss: leaving the stressed 'me' in clitic position. The must_not_include catches it.",
    "version": 1
  },
  {
    "external_id": "op_dop_mi_02",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.mi",
    "difficulty": 1,
    "cefr_level_target": "A2",
    "prompt": "Complete with the direct-object pronoun for 'me': 'Anna ____ aspetta in piazza.'",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.mi",
        "label": "DOP 1sg in finite tense, pre-verb",
        "any_phrases": [
          "mi"
        ],
        "must_not_include": [
          "me",
          "io"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "aspetta",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "aspettare - to wait for",
            "bucket": "vocabulary.it.aspettare.translation"
          }
        }
      },
      {
        "lemma": "piazza",
        "language": "it",
        "aspects": {
          "translation": {
            "reveal": "piazza - square",
            "bucket": "vocabulary.it.piazza.translation"
          }
        }
      }
    ],
    "explanation": "'Anna mi aspetta in piazza' means 'Anna is waiting for me in the square'. Aspettare takes a direct object in Italian, with no preposition (unlike English 'wait FOR'). The 1sg DOP is mi, in pre-verb position: 'Anna mi aspetta'.",
    "version": 1
  },
  {
    "external_id": "op_dop_mi_03",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.mi",
    "difficulty": 2,
    "cefr_level_target": "B1",
    "prompt": "Translate the bracketed pronoun. '[Me] hai chiamato ieri sera.' → '____ hai chiamato ieri sera.'",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.mi",
        "label": "DOP 1sg in passato prossimo, pre-aux",
        "any_phrases": [
          "mi"
        ],
        "must_not_include": [
          "me",
          "m'",
          "io"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "chiamato",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "chiamare - to call",
            "bucket": "vocabulary.it.chiamare.translation"
          }
        }
      }
    ],
    "explanation": "'Mi hai chiamato ieri sera' means 'You called me last night'. In compound tenses the clitic sits in pre-verb position, before the auxiliary. With 1sg/2sg/1pl/2pl DOPs the past participle stays invariable in modern usage. Stack: mi + hai + chiamato giving 'mi hai chiamato'.",
    "examiner_note": "The participle-agreement bucket is intentionally not touched here; this item only tests pronoun selection and placement.",
    "version": 1
  },
  {
    "external_id": "op_dop_ti_01",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.ti",
    "difficulty": 1,
    "cefr_level_target": "A2",
    "prompt": "Replace 'te' with a pronoun: 'Io vedo te al bar.' → 'Io ____ vedo al bar.'",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.ti",
        "label": "DOP 2sg informal",
        "any_phrases": [
          "ti"
        ],
        "must_not_include": [
          "te",
          "tu",
          "a te"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "vedo",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "vedere - to see",
            "bucket": "vocabulary.it.vedere.translation"
          }
        }
      }
    ],
    "explanation": "'Io ti vedo al bar' means 'I see you at the bar'. Italian has two parallel object forms for 2sg informal: the clitic ti and the stressed pronoun te. The clitic ti is the default pre-verb form; te appears after prepositions (a te, con te) or for contrast.",
    "version": 1
  },
  {
    "external_id": "op_dop_ti_02",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.ti",
    "difficulty": 1,
    "cefr_level_target": "A2",
    "prompt": "Complete: '____ aspetto fuori.' (saying 'I'll wait for you' to a friend)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.ti",
        "label": "DOP 2sg informal pre-verb",
        "any_phrases": [
          "ti"
        ],
        "must_not_include": [
          "te",
          "la",
          "lo",
          "vi"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "aspetto",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "aspettare - to wait for",
            "bucket": "vocabulary.it.aspettare.translation"
          }
        }
      }
    ],
    "explanation": "'Ti aspetto fuori' means 'I'll wait for you outside'. The cue 'to a friend' picks out the informal singular addressee. The DOP is ti. (Formal address would use La; plural would use vi.)",
    "examiner_note": "The register cue ('to a friend') disambiguates from 'La' (formal) and 'vi' (plural).",
    "version": 1
  },
