    "vocab_help": [
      {
        "lemma": "fido",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "fidarsi - to trust (fidarsi di + person/thing)",
            "bucket": "vocabulary.it.fidarsi.translation"
          }
        }
      }
    ],
    "explanation": "'Mi fido di lei' means 'I trust her'. Fidarsi takes 'di + person/thing'. The pronoun form after a preposition is the stressed pronoun, not a DOP or IOP: di lei, never 'la' or 'le'. Not every English transitive maps to an Italian clitic.",
    "examiner_note": "Tests recognition that some Italian verbs lock the preposition + stressed-pronoun pattern. Could also be 'me ne fido' for thing-antecedents, but for person-antecedents the prepositional phrase is the unmarked choice.",
    "version": 1
  },
  {
    "external_id": "op_iop_no_pp_agree_01",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "indirect_object.gli_masc",
    "difficulty": 3,
    "cefr_level_target": "B2",
    "prompt": "Choose the right participle form: 'Marco ha tre sorelle. Ieri ____ ho parlat____ a lungo.' (= I spoke to him for a long time)",
    "type": "mcq",
    "marks": 1,
    "choices": [
      "gli / parlato",
      "gli / parlata",
      "lo / parlato",
      "gli / parlati"
    ],
    "answer_index": 0,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.indirect_object.gli_masc",
        "label": "IOPs do NOT trigger participle agreement",
        "any_phrases": [
          "gli / parlato"
        ],
        "must_not_include": [
          "gli / parlata",
          "lo / parlato"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "parlato",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "parlare - to speak (parlare a + person)",
            "bucket": "vocabulary.it.parlare.translation"
          }
        }
      }
    ],
    "explanation": "'Marco ha tre sorelle. Ieri gli ho parlato a lungo' means 'Marco has three sisters. Yesterday I spoke to him for a long time'. IOPs never trigger participle agreement, even pre-verb. The participle stays invariable: 'gli ho parlato', not 'gli ho parlati'. Only DOPs (la/lo/le/li) and partitive ne trigger agreement.",
    "examiner_note": "Important diagnostic. Common miss: agreeing the participle with the IOP's gender/number. The 'sorelle' detail in the prompt is a red herring designed to encourage the wrong agreement.",
    "version": 1
  },
  {
    "external_id": "op_dop_ti_03",
    "language_code": "it",
