    "type": "short",
    "marks": 2,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.indirect_object.verbs_taking_iop.with_essere_in_pp",
        "label": "Piacere PP: IOP gli (or kept as 'a Marco' resumed)",
        "any_phrases": [
          "gli",
          "è"
        ],
        "must_not_include": [
          "lo",
          "li"
        ]
      },
      {
        "order_index": 1,
        "credit": 1.0,
        "bucket": "verb_form.passato_prossimo.auxiliary.essere_other_intransitive",
        "label": "Piacere aux is essere; participle agrees with subject (la festa, f.sg)",
        "any_phrases": [
          "è piaciuta"
        ],
        "must_not_include": [
          "ha piaciuto",
          "è piaciuto",
          "piace",
          "piaceva"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "festa",
        "language": "it",
        "aspects": {
          "translation": {
            "reveal": "festa - party",
            "bucket": "vocabulary.it.festa.translation"
          },
          "gender": {
            "reveal": "feminine (f)",
            "bucket": "vocabulary.it.festa.gender"
          }
        }
      }
    ],
    "explanation": "'Ieri sera, a Marco gli è piaciuta molto la festa' means 'Yesterday evening, Marco really liked the party'. Piacere in passato prossimo: aux essere, with the participle agreeing with the grammatical subject (the thing liked). La festa is f.sg → piaciuta. The fronted 'a Marco' is resumed by the IOP gli.",
    "examiner_note": "Cross-references verb_form.passato_prossimo. Two markpoints; the engine will attribute the auxiliary/agreement miss separately from the pronoun miss.",
    "version": 1
  },
