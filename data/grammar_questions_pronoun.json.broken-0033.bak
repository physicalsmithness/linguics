        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "andarsene - to leave",
            "bucket": "vocabulary.it.andarsene.translation"
          }
        }
      }
    ],
    "explanation": "'Era tardi e Marco se n'era andato senza salutare' means 'It was late and Marco had gone off without saying goodbye'. Andarsene is a pronominal verb of motion; reflexive si triggers essere as auxiliary. Trapassato prossimo for 3sg m gives era andato. Stack: se + n' (elided from ne before è) + era + andato.",
    "examiner_note": "Two markpoints. Accepts both 'se n'era' (elided, standard) and 'se ne era' (unelided, also acceptable). Cross-references trapassato_prossimo.",
    "version": 1
  },
  {
    "external_id": "op_ne_motion_02",
