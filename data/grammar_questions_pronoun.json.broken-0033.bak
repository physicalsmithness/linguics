    "prompt": "Marco aveva le mani sporche. Complete: 'Marco ____ lavate ieri.' (= Marco washed them for himself)",
    "type": "short",
    "marks": 2,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.reflexive.with_object",
