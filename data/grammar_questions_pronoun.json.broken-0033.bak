        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "salutati",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "salutare - to greet",
            "bucket": "vocabulary.it.salutare.translation"
          }
        }
      }
    ],
    "explanation": "'Marco ci ha salutati alla stazione' means 'Marco said hello to us at the station'. Salutare takes a direct object → DOP. The ci here is 1pl DOP. The participle agreement gives the default m.pl salutati. (The distractors show locative ci with andare, or wrong-form ne.)",
    "examiner_note": "Tests the form-identification at the level of surface ambiguity (ci as DOP vs locative vs reflexive).",
    "version": 1
  },
  {
    "external_id": "op_dop_vi_you_03",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.vi_you",
    "difficulty": 3,
    "cefr_level_target": "B2",
    "prompt": "Rewrite in the negative: 'Ragazze, vi ho viste ieri al parco.' → '____.' (informal: I didn't see you all, addressing women)",
    "type": "short",
    "marks": 2,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.vi_you",
        "label": "DOP 2pl vi, pre-aux",
        "any_phrases": [
          "vi ho",
          "Non vi ho"
        ],
        "must_not_include": [
          "ho vi",
          "voi ho"
        ]
      },
      {
        "order_index": 1,
        "credit": 1.0,
        "bucket": "verb_form.passato_prossimo.participle_agreement.with_avere.preceding_dop_mi_ti_ci_vi",
        "label": "Participle ending: agreement with vi is optional (viste/visto both credited)",
        "any_phrases": [
          "viste",
          "visto"
        ],
        "must_not_include": [
          "visti",
          "vista"
        ]
      }
    ],
    "vocab_help": [],
    "explanation": "'Ragazze, non vi ho viste ieri al parco' means 'Girls, I didn't see you at the park yesterday'. The 2pl DOP vi sits pre-aux. Participle agreement with the 1/2-person DOPs (mi, ti, ci, vi) is optional in modern Italian: the agreed form (viste, f.pl matching ragazze) feels more typical in narrative or literary register; the invariable visto is everyday. Both are credited; wrong-gender forms are not.",
    "examiner_note": "Both Non vi ho viste (agreement, register-cued by the prompt) and Non vi ho visto (invariable, everyday) credit. Wrong-gender/number (visti, vista) caught.",
    "version": 1
  },
  {
    "external_id": "op_dop_formal_La_03",
    "language_code": "it",
    "topic": "pronoun",
    "subtopic": "direct_object.formal_La",
    "difficulty": 3,
    "cefr_level_target": "B2",
    "prompt": "Spoken polite context. 'Doctor, I'd recognise you anywhere.' → 'Dottore, ____ riconoscerei ovunque.'",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": false,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "pronoun.direct_object.formal_La",
        "label": "Formal La addressing a male professional",
        "any_phrases": [
          "La",
          "la"
        ],
        "must_not_include": [
          "Lo",
          "Ti",
          "Le"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "riconoscerei",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "riconoscere - to recognise",
            "bucket": "vocabulary.it.riconoscere.translation"
          }
        }
      }
    ],
    "explanation": "'Dottore, La riconoscerei ovunque' means 'Doctor, I'd recognise you anywhere'. Formal address uses Lei (grammatically feminine) regardless of the addressee's biological gender. The DOP is La for both men and women in formal register; don't switch to Lo for a male.",
    "examiner_note": "Common confusion: thinking 'La' is feminine and switching to 'Lo' for a man. The formal-Lei is grammatically feminine throughout.",
    "version": 1
  },
