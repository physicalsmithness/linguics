        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "lavate",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "lavarsi - to wash oneself / a part of oneself",
            "bucket": "vocabulary.it.lavarsi.translation"
          }
        }
      }
    ],
    "explanation": "'Marco aveva le mani sporche. Marco se le è lavate ieri' means 'Marco had dirty hands. Marco washed them yesterday'. Reflexive 3sg si undergoes the vowel change to se before le. Aux essere (reflexive). When the DOP is overt in the cluster, the participle agrees with it, not with the subject. Stack: se + le + è + lavate giving 'se le è lavate' (or elided 'se l'è lavate').",
    "examiner_note": "Tests reflexive + DOP cluster in PP with participle agreement to the preceding DOP. Complex; hot pattern.",
    "version": 1
  },
