    "vocab_help": [
      {
        "lemma": "vado",
        "language": "it",
        "aspects": {
          "infinitive": {
            "reveal": "andare - to go",
            "bucket": "vocabulary.it.andare.translation"
          }
        }
      }
    ],
    "explanation": "'Vai a Roma domani? Sì, ci vado domani' means 'Are you going to Rome tomorrow? Yes, I'm going there tomorrow'. When you want to say 'there' for a known location, Italian uses the locative ci. It replaces phrases like 'a Roma'. The emphatic là/lì exists but is more marked; ci is the everyday form.",
    "examiner_note": "Diagnostic miss: 'vado là' (overly literal, valid but more marked).",
    "version": 1
  },
  {
