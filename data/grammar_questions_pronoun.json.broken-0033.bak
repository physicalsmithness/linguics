        "bucket": "verb_form.passato_prossimo.participle_agreement.with_avere.preceding_dop_mi_ti_ci_vi",
        "label": "Participle m.pl agreement with preceding 1pl DOP ci",
        "any_phrases": [
          "salutati"
        ],
        "must_not_include": [
          "salutato",
          "salutata",
