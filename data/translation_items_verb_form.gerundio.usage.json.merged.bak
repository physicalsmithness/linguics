[
  {
    "external_id": "trans_ger_en_it_use_mm_01",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "You learn by making mistakes.",
    "reference_translations": [
      {
        "text": "Sbagliando si impara.",
        "register": "neutral",
        "notes": "Standard proverb. The means gerund renders English 'by ...-ing'; impersonal si for the generic 'you'."
      },
      {
        "text": "Si impara sbagliando.",
        "register": "neutral",
        "notes": "Same sentence, gerund after the main verb; equally natural."
      },
      {
        "text": "Si impara per sbagliare.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "WRONG: per + infinitive is PURPOSE ('in order to make mistakes'), not means. English 'by ...-ing' for means is the gerund, not per."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "required_buckets": [
      "verb_form.gerundio.usage.modal_means"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "learn",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to learn - imparare", "bucket": "vocabulary.it.imparare.verb.translation" }
        }
      },
      {
        "lemma": "mistakes",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to make a mistake - sbagliare", "bucket": "vocabulary.it.sbagliare.verb.translation" }
        }
      }
    ],
    "explanation": "'Sbagliando si impara' is the standard rendering of 'You learn by making mistakes'. English 'by ...-ing' expressing means maps onto the bare adverbial gerund (sbagliando), never onto per + infinitive, which would express purpose. The generic 'you' is the impersonal si.",
    "version": 1
  },
  {
    "external_id": "trans_ger_en_it_use_mm_02",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "She greeted us smiling.",
    "reference_translations": [
      {
        "text": "Ci ha salutati sorridendo.",
        "register": "neutral",
        "notes": "Manner gerund. Participle salutati agrees with the masculine/mixed 'us' (avere + preceding ci is optional agreement; salutato also heard)."
      },
      {
        "text": "Ci ha salutato sorridendo.",
        "register": "neutral",
        "notes": "Participle left invariable; also standard with avere and a preceding ci."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "required_buckets": [
      "verb_form.gerundio.usage.modal_means"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "greeted",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to greet - salutare", "bucket": "vocabulary.it.salutare.verb.translation" }
        }
      },
      {
        "lemma": "smiling",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to smile - sorridere", "bucket": "vocabulary.it.sorridere.verb.translation" }
        }
      }
    ],
    "explanation": "'Ci ha salutati sorridendo' means 'She greeted us smiling'. The manner gerund (sorridendo) says how she greeted. Its subject is the same as the main verb's (she both smiled and greeted), which is what licenses the bare gerund.",
    "version": 1
  },
  {
    "external_id": "trans_ger_en_it_use_mm_03",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "You learn a language by speaking it.",
    "reference_translations": [
      {
        "text": "Si impara una lingua parlandola.",
        "register": "neutral",
        "notes": "Means gerund with the clitic la attached: parlandola. Impersonal si for generic 'you'."
      },
      {
        "text": "Una lingua si impara parlandola.",
        "register": "neutral",
        "notes": "Object fronted for emphasis; equally natural."
      },
      {
        "text": "Si impara una lingua per parlarla.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "WRONG sense: per + infinitive says you learn it in order to speak it (purpose), not by speaking it (means)."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 4,
    "cefr_level_target": "B2",
    "required_buckets": [
      "verb_form.gerundio.usage.modal_means"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "language",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "language - lingua", "bucket": "vocabulary.it.lingua.noun.translation" }
        }
      },
      {
        "lemma": "speaking",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to speak - parlare", "bucket": "vocabulary.it.parlare.verb.translation" }
        }
      }
    ],
    "explanation": "'Si impara una lingua parlandola' means 'You learn a language by speaking it'. The means gerund carries the 'by ...-ing', and the object clitic la attaches to the end of the gerund (parlandola). Rendering it with per parlarla would change the meaning to purpose ('in order to speak it').",
    "version": 1
  },
  {
    "external_id": "trans_ger_en_it_use_tc_01",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "Coming home, I met an old friend.",
    "reference_translations": [
      {
        "text": "Tornando a casa, ho incontrato un vecchio amico.",
        "register": "neutral",
        "notes": "Temporal gerund opening the sentence, standing in for 'mentre tornavo a casa'."
      },
      {
        "text": "Mentre tornavo a casa, ho incontrato un vecchio amico.",
        "register": "neutral",
        "credit": 0.9,
        "notes": "Correct, but sidesteps the gerund with an explicit temporal clause. Credit 0.9 with a steer toward the gerund 'tornando', which the item drills."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 4,
    "cefr_level_target": "B2",
    "required_buckets": [
      "verb_form.gerundio.usage.temporal_causal"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "coming",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to return / to come back - tornare", "bucket": "vocabulary.it.tornare.verb.translation" }
        }
      },
      {
        "lemma": "friend",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "friend - amico", "bucket": "vocabulary.it.amico.noun.translation" }
        }
      }
    ],
    "explanation": "'Tornando a casa, ho incontrato un vecchio amico' means 'Coming home, I met an old friend'. The temporal gerund reduces 'while I was coming home' to a single word. The same subject (I) returns and meets, so the gerund is licensed; a full clause (mentre tornavo) is also correct but is what this item asks you to compress.",
    "version": 1
  },
  {
    "external_id": "trans_ger_en_it_use_tc_02",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "Not knowing what to say, she stayed silent.",
    "reference_translations": [
      {
        "text": "Non sapendo cosa dire, è rimasta in silenzio.",
        "register": "neutral",
        "notes": "Causal gerund negated with non; participle rimasta agrees with the feminine subject (rimanere takes essere)."
      },
      {
        "text": "Non sapendo che cosa dire, è rimasta zitta.",
        "register": "neutral",
        "notes": "'che cosa' and 'zitta' are equally natural variants."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 4,
    "cefr_level_target": "B2",
    "required_buckets": [
      "verb_form.gerundio.usage.temporal_causal"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "knowing",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to know - sapere", "bucket": "vocabulary.it.sapere.verb.translation" }
        }
      }
    ],
    "explanation": "'Non sapendo cosa dire, è rimasta in silenzio' means 'Not knowing what to say, she stayed silent'. The causal gerund explains why she stayed silent, and is negated by simply putting non before it. The subject is the same throughout (she did not know and she stayed silent).",
    "version": 1
  },
  {
    "external_id": "trans_ger_en_it_use_tc_03",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "Having finished the work, he went out.",
    "reference_translations": [
      {
        "text": "Avendo finito il lavoro, è uscito.",
        "register": "neutral",
        "notes": "Compound gerund for an action prior to the main one; avere because finire has a direct object, invariable participle finito."
      },
      {
        "text": "Finito il lavoro, è uscito.",
        "register": "neutral",
        "notes": "The bare past participle (finito il lavoro) is an equally idiomatic way to express the same anteriority."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 4,
    "cefr_level_target": "B2",
    "required_buckets": [
      "verb_form.gerundio.usage.temporal_causal",
      "verb_form.gerundio.formation.gerundio_passato"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "finished",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to finish - finire", "bucket": "vocabulary.it.finire.verb.translation" }
        }
      },
      {
        "lemma": "work",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "work - lavoro", "bucket": "vocabulary.it.lavoro.noun.translation" }
        }
      }
    ],
    "explanation": "'Avendo finito il lavoro, è uscito' means 'Having finished the work, he went out'. Because the finishing happened BEFORE the going out, Italian uses the compound gerund (avendo + participle), not the simple gerund. This one sentence exercises both the usage (a gerund heading a subordinate of prior time) and the compound form, so both buckets are credited.",
    "version": 1
  },
  {
    "external_id": "trans_ger_en_it_use_tc_samesubj_01",
    "source_lang": "en",
    "target_lang": "it",
    "source_text": "While I was cooking, the phone rang.",
    "reference_translations": [
      {
        "text": "Mentre cucinavo, il telefono ha squillato.",
        "register": "neutral",
        "notes": "Two different subjects (I / the phone), so Italian must keep a full clause; a gerund is NOT available here."
      },
      {
        "text": "Mentre cucinavo, ha squillato il telefono.",
        "register": "neutral",
        "notes": "Subject after the verb; equally natural."
      },
      {
        "text": "Cucinando, il telefono ha squillato.",
        "register": "neutral",
        "polarity": "negative",
        "notes": "WRONG: the gerund's implicit subject would be the phone, saying the phone was cooking. The same-subject rule forbids the gerund when the two subjects differ."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 4,
    "cefr_level_target": "B2",
    "required_buckets": [
      "verb_form.gerundio.usage.temporal_causal"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "cooking",
        "language": "en",
        "aspects": {
          "translation": { "reveal": "to cook - cucinare", "bucket": "vocabulary.it.cucinare.verb.translation" }
        }
      }
    ],
    "explanation": "'Mentre cucinavo, il telefono ha squillato' means 'While I was cooking, the phone rang'. This item tests when NOT to use the gerund: the cook (I) and the ringer (the phone) are different subjects, so the adverbial gerund is unavailable and Italian keeps a full clause with mentre. Using 'cucinando' would wrongly say the phone was cooking.",
    "version": 1
  },
  {
    "external_id": "trans_ger_it_en_use_mm_01",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "È uscito sbattendo la porta.",
    "reference_translations": [
      {
        "text": "He left slamming the door.",
        "register": "neutral",
        "notes": "Manner gerund -> English -ing of manner."
      },
      {
        "text": "He went out, slamming the door.",
        "register": "neutral",
        "notes": "Equally natural; the comma is optional in English."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "required_buckets": [
      "verb_form.gerundio.usage.modal_means"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "sbattendo",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "to slam / to bang - sbattere", "bucket": "vocabulary.it.sbattere.verb.translation" }
        }
      },
      {
        "lemma": "porta",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "door - porta", "bucket": "vocabulary.it.porta.noun.translation" }
        }
      }
    ],
    "explanation": "'È uscito sbattendo la porta' means 'He left slamming the door'. The manner gerund sbattendo describes how he left, and English renders it with its own -ing of manner. The slammer and the leaver are the same, as the Italian gerund requires.",
    "version": 1
  },
  {
    "external_id": "trans_ger_it_en_use_tc_concessive_01",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "Pur essendo giovane, è molto saggio.",
    "reference_translations": [
      {
        "text": "Although he is young, he is very wise.",
        "register": "neutral",
        "notes": "pur + gerund = concessive 'although'."
      },
      {
        "text": "Young as he is, he is very wise.",
        "register": "neutral",
        "notes": "Idiomatic concessive; captures the same 'although' sense."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 5,
    "cefr_level_target": "C1",
    "required_buckets": [
      "verb_form.gerundio.usage.temporal_causal"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "giovane",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "young - giovane", "bucket": "vocabulary.it.giovane.adjective.translation" }
        }
      },
      {
        "lemma": "saggio",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "wise - saggio", "bucket": "vocabulary.it.saggio.adjective.translation" }
        }
      }
    ],
    "explanation": "'Pur essendo giovane, è molto saggio' means 'Although he is young, he is very wise'. The marker pur in front of a gerund turns it concessive ('although / even though'); without pur, essendo giovane would read as cause ('being young'). English uses an 'although' clause.",
    "version": 1
  },
  {
    "external_id": "trans_ger_it_en_use_tc_conditional_01",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "Volendo, potremmo partire subito.",
    "reference_translations": [
      {
        "text": "If we wanted, we could leave right away.",
        "register": "neutral",
        "notes": "Conditional gerund -> English 'if' clause."
      },
      {
        "text": "If we wanted to, we could leave immediately.",
        "register": "neutral",
        "notes": "Equally natural."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 4,
    "cefr_level_target": "B2",
    "required_buckets": [
      "verb_form.gerundio.usage.temporal_causal"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "volendo",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "to want - volere", "bucket": "vocabulary.it.volere.verb.translation" }
        }
      },
      {
        "lemma": "partire",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "to leave / to depart - partire", "bucket": "vocabulary.it.partire.verb.translation" }
        }
      }
    ],
    "explanation": "'Volendo, potremmo partire subito' means 'If we wanted, we could leave right away'. The gerund can carry a conditional sense ('if ...'), and English renders it with an 'if' clause. 'Volendo' alone is a set idiom meaning 'if one wishes / it can be done'.",
    "version": 1
  },
  {
    "external_id": "trans_ger_it_en_use_tc_causal_01",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "Essendo domenica, i negozi erano chiusi.",
    "reference_translations": [
      {
        "text": "It being Sunday, the shops were closed.",
        "register": "neutral",
        "notes": "Causal gerund; English keeps the slightly formal 'it being ...' or uses 'since'."
      },
      {
        "text": "Since it was Sunday, the shops were closed.",
        "register": "neutral",
        "notes": "More everyday English for the same causal sense."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 4,
    "cefr_level_target": "B2",
    "required_buckets": [
      "verb_form.gerundio.usage.temporal_causal"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "domenica",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "Sunday - domenica", "bucket": "vocabulary.it.domenica.noun.translation" }
        }
      },
      {
        "lemma": "negozi",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "shop - negozio", "bucket": "vocabulary.it.negozio.noun.translation" }
        }
      }
    ],
    "explanation": "'Essendo domenica, i negozi erano chiusi' means 'It being Sunday, the shops were closed'. The causal gerund essendo gives the reason; English can keep the formal 'it being ...' or switch to 'since it was ...'. This causal use is common in written and slightly formal Italian.",
    "version": 1
  },
  {
    "external_id": "trans_ger_it_en_use_mm_02",
    "source_lang": "it",
    "target_lang": "en",
    "source_text": "Ho passato la serata leggendo.",
    "reference_translations": [
      {
        "text": "I spent the evening reading.",
        "register": "neutral",
        "notes": "Means/activity gerund -> English -ing."
      }
    ],
    "topic": "verb_form.gerundio",
    "register": "neutral",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "required_buckets": [
      "verb_form.gerundio.usage.modal_means"
    ],
    "optional_buckets": [],
    "vocab_help": [
      {
        "lemma": "serata",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "evening - serata", "bucket": "vocabulary.it.serata.noun.translation" }
        }
      },
      {
        "lemma": "leggendo",
        "language": "it",
        "aspects": {
          "translation": { "reveal": "to read - leggere", "bucket": "vocabulary.it.leggere.verb.translation" }
        }
      }
    ],
    "explanation": "'Ho passato la serata leggendo' means 'I spent the evening reading'. The gerund names the activity that filled the evening, and maps directly onto English -ing. Same subject throughout (I spent, I read).",
    "version": 1
  }
]
