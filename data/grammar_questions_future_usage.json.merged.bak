[
  {
    "external_id": "fu_prob_01",
    "info_display": "suppress",
    "language_code": "it",
    "topic": "verb_form.future",
    "subtopic": "usage.probability",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "prompt": "Completa con una supposizione: 'Che ore sono?' 'Non ho l'orologio, ma ____ le tre.' (essere)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": true,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "verb_form.future.usage.probability",
        "label": "future for a present guess (saranno)",
        "any_phrases": [
          {
            "phrase": "saranno",
            "match_at": "word"
          }
        ],
        "must_not_include": [
          "sono"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "essere",
        "language": "it",
        "aspects": {
          "translation": {
            "reveal": "essere - to be",
            "bucket": "vocabulary.it.essere.verb.translation"
          }
        }
      }
    ],
    "explanation": "'It must be about three o'clock': Non ho l'orologio, ma saranno le tre. Italian uses the future not only for time to come but to make a GUESS about the present: 'saranno le tre' means 'it's probably three', not 'it will be three'. The present 'sono le tre' would be a statement of fact, but the speaker is guessing, so the future carries the supposition. This is the future of probability, and it has no English equivalent tense (English uses 'must be' or 'probably').",
    "examiner_note": "Suppressed: a 'future of probability' breadcrumb hands over that the guess wants the future, which is the whole skill. The present 'sono' is the criterion-10b wrong-form catch.",
    "version": 1
  },
  {
    "external_id": "fu_prob_02",
    "info_display": "suppress",
    "language_code": "it",
    "topic": "verb_form.future",
    "subtopic": "usage.probability",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "prompt": "Completa con una supposizione: 'Quanti anni ha il nuovo professore?' 'Non lo so, ____ una quarantina d'anni.' (avere)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": true,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "verb_form.future.usage.probability",
        "label": "future for a present guess (avrà)",
        "any_phrases": [
          {
            "phrase": "avrà",
            "match_at": "word"
          }
        ],
        "must_not_include": [
          "ha"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "avere",
        "language": "it",
        "aspects": {
          "translation": {
            "reveal": "avere - to have",
            "bucket": "vocabulary.it.avere.verb.translation"
          }
        }
      }
    ],
    "explanation": "'He's probably about forty': Non lo so, avrà una quarantina d'anni. To guess someone's age Italian uses the future: 'avrà quarant'anni' means 'he's probably forty', a supposition about the present. The plain present 'ha quarant'anni' would state it as a known fact; the speaker does not know, so the future of probability carries the guess.",
    "examiner_note": "Suppressed for the same reason as fu_prob_01. 'ha' is the present-tense catch (criterion 10b).",
    "version": 1
  },
  {
    "external_id": "fu_prob_03",
    "info_display": "suppress",
    "language_code": "it",
    "topic": "verb_form.future",
    "subtopic": "usage.probability",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "prompt": "Completa con una supposizione: 'Dov'è Anna?' 'Non è in ufficio, ____ già a casa.' (essere)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": true,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "verb_form.future.usage.probability",
        "label": "future for a present guess (sarà)",
        "any_phrases": [
          {
            "phrase": "sarà",
            "match_at": "word"
          }
        ],
        "must_not_include": [
          "è già",
          "e già"
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "essere",
        "language": "it",
        "aspects": {
          "translation": {
            "reveal": "essere - to be",
            "bucket": "vocabulary.it.essere.verb.translation"
          }
        }
      }
    ],
    "explanation": "'She's probably home already': Non è in ufficio, sarà già a casa. Guessing where someone is right now, Italian reaches for the future: 'sarà a casa' means 'she's probably home', a supposition about the present moment. The present 'è a casa' would assert it as fact; the future of probability marks it as an inference.",
    "examiner_note": "Suppressed for the same reason as the other probability items. The present 'è' (here 'è già') is the wrong-form catch; the two-word guard avoids a bare one-letter è.",
    "version": 1
  },
  {
    "external_id": "fu_prob_04",
    "info_display": "suppress",
