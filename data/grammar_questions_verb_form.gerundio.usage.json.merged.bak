[
  {
    "external_id": "ger_use_mm_sbagliare_01",
    "language_code": "it",
    "topic": "verb_form.gerundio",
    "subtopic": "usage.modal_means",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "prompt": "Esprimi il mezzo con un gerundio [it is by making mistakes that one learns]: '____ s'impara.' (sbagliare)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": true,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "verb_form.gerundio.usage.modal_means",
        "label": "sbagliando (adverbial gerund of means)",
        "any_phrases": [
          {
            "phrase": "sbagliando",
            "match_at": "word"
          }
        ],
        "must_not_include": [
          {
            "phrase": "si sbaglia",
            "match_at": "word"
          }
        ]
      }
    ],
    "vocab_help": [
      {
        "lemma": "sbagliare",
        "language": "it",
        "aspects": {
          "translation": {
            "reveal": "sbagliare - to make a mistake / to be wrong",
            "bucket": "vocabulary.it.sbagliare.verb.translation"
          }
        }
      }
    ],
    "explanation": "'Sbagliando s'impara' means 'One learns by making mistakes' (a proverb). The bare gerund, without stare, works like an adverb on the main verb: here it answers 'by what means?'. The means gerund is the plain -ando / -endo form, so sbagliare gives sbagliando. Its unspoken subject is the same as the main clause's (the same 'one' both errs and learns), which is the rule that governs every adverbial gerund.",
    "version": 1
  },
  {
    "external_id": "ger_use_mm_correre_01",
    "language_code": "it",
    "topic": "verb_form.gerundio",
    "subtopic": "usage.modal_means",
    "difficulty": 3,
    "cefr_level_target": "B1",
    "prompt": "Esprimi il modo con un gerundio [running]: 'È entrato in classe ____.' (correre)",
    "type": "short",
    "marks": 1,
    "prompt_supplies_base_form": true,
    "markpoints": [
      {
        "order_index": 0,
        "credit": 1.0,
        "bucket": "verb_form.gerundio.usage.modal_means",
        "label": "correndo (adverbial gerund of manner)",
        "any_phrases": [
