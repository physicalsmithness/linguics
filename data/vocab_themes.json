{
  "version": 3,
  "description": "Themes taxonomy for Linguics vocabulary entries. Every vocab entry carries a `themes` array; values are drawn from this registry. Themes mix semantic categories (food_drink, colours, days_of_week) with grammatical-functional ones (function_word, modal_verb, verb_movement). Consumers can partition by prefix where useful (verb_*, pronoun_*, adjective_*, adverb_*, determiner_*). Themes may have a `parent_id` indicating a parent theme; convention is that entries tagged with a child theme are ALSO tagged with its parent, so a 'show me food vocabulary' query can simply check for 'food_drink' membership without walking the hierarchy. Consumers wanting finer slices use the child theme directly.",
  "kinds": {
    "semantic_concrete": "Real-world domains: people, places, things, time, sensations",
    "semantic_abstract": "Abstract domains: emotions, mental_state, noun_abstract, etc.",
    "functional": "Grammatical role / word-class function: function_word, pronoun_*, determiner_*",
    "verb_subtype": "Semantic / aspectual sub-category for verb lemmas",
    "adjective_subtype": "Semantic sub-category for adjective lemmas",
    "adverb_subtype": "Semantic sub-category for adverb lemmas"
  },
